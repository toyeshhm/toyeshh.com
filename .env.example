# Optional: override the default Formspree URL from src/lib/contact.ts (FORMSPREE_FORM_URL).
# Create a form at https://formspree.io and paste the endpoint here; restart dev server after changing.
# VITE_FORMSPREE_URL=https://formspree.io/f/your_form_id

# Preferred chatbot provider for the server-side terminal agent proxy
GEMINI_API_KEY=your_gemini_api_key_here

# Optional fallback provider if Gemini is unavailable
MISTRAL_API_KEY=your_mistral_api_key_here
